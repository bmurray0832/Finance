# Backend configuration for the finance tracker server.
# In production (Railway) set these as service variables.

# --- Auth (the shared household login) ---
AUTH_EMAIL=you@example.com
AUTH_PASSWORD=change-this-to-a-strong-passphrase

# --- Session signing ---
# Any long random string. Rotating it logs everyone out.
JWT_SECRET=please-generate-a-long-random-secret

# --- Database ---
# Provided automatically by the Railway Postgres plugin. When unset, the
# server falls back to a local JSON file (server/.data.json) for dev only.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Set to true if your Postgres requires SSL (some managed providers do).
# DATABASE_SSL=false

# Railway sets PORT automatically; NODE_ENV should be "production" there.
# NODE_ENV=production
